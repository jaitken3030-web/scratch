# Copy to .env — never commit the real file.

# Kalshi API key (create under Account > API keys; download the RSA private key)
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=./kalshi-private-key.pem

# Polymarket CLOB API credentials (derived from your wallet via the CLOB)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
# Wallet private key — ONLY needed for live order signing. Leave empty for dry-run.
POLYMARKET_PRIVATE_KEY=

# Optional: webhook for safety alerts (Slack/Discord-compatible JSON POST)
ALERT_WEBHOOK_URL=
